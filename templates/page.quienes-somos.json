{"sections":{"main":{"type":"main-page","disabled":true,"settings":{"content_direction":"column","content_direction_mobile":"column","horizontal_alignment":"flex-start","vertical_alignment":"center","align_baseline":false,"horizontal_alignment_flex_direction_column":"flex-start","vertical_alignment_flex_direction_column":"center","gap":12,"section_width":"page-width","page_width_custom":1570,"section_height":"","section_height_custom":50,"color_scheme":"","background_media":"none","video_position":"cover","background_image_position":"cover","border":"none","border_width":1,"border_radius":0,"toggle_overlay":false,"overlay_color":"#00000026","overlay_style":"solid","gradient_direction":"to top","image_behavior":"none","padding-block-start":36,"padding-block-end":36}},"hero":{"type":"custom-liquid","settings":{"custom_liquid":"<style>@import url('https:\/\/fonts.googleapis.com\/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@300;400;500;600;700&display=swap');.zdc-hero{position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;overflow:hidden;background:#070E23}.zdc-hero-bg{position:absolute;inset:0;background:url('{{ 'zdc-dsc00393.jpg' | asset_url }}') center\/cover no-repeat;opacity:0.25;z-index:0}.zdc-hero-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(7,14,35,0.7) 0%,rgba(7,14,35,0.9) 100%);z-index:1}.zdc-hero-content{position:relative;z-index:2;padding:40px 20px;max-width:900px}.zdc-hero-content h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(3.5rem,10vw,8rem);color:#fff;letter-spacing:6px;margin:0 0 20px;line-height:1}.zdc-hero-content p{font-family:'Barlow Condensed',sans-serif;font-size:clamp(1rem,2.5vw,1.5rem);color:rgba(255,255,255,0.8);font-weight:300;letter-spacing:2px;margin:0 0 40px}.zdc-hero-logo{width:clamp(120px,20vw,220px);margin:0 auto;filter:brightness(1.1)}.zdc-r{opacity:0;transform:translateY(40px);transition:opacity 0.8s ease,transform 0.8s ease}.zdc-r.zdc-visible{opacity:1;transform:translateY(0)}<\/style><div class=\"zdc-hero\"><div class=\"zdc-hero-bg\"><\/div><div class=\"zdc-hero-overlay\"><\/div><div class=\"zdc-hero-content zdc-r\"><h1>QUIÉNES SOMOS<\/h1><p>EL MEJOR GIMNASIO DE ARTES MARCIALES MIXTAS EN COLOMBIA<\/p><img src=\"{{ 'Logo zona gris.png' | asset_url }}\" alt=\"Zona de Combate Logo\" class=\"zdc-hero-logo\"><\/div><\/div><script>document.addEventListener('DOMContentLoaded',function(){const obs=new IntersectionObserver((entries)=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('zdc-visible');obs.unobserve(e.target)}})},{threshold:0.15});document.querySelectorAll('.zdc-r').forEach(el=>obs.observe(el))});<\/script>","color_scheme":"scheme-1","padding_top":0,"padding_bottom":0}},"historia":{"type":"custom-liquid","settings":{"custom_liquid":"<style>.zdc-historia{background:#070E23;padding:100px 20px;overflow:hidden}.zdc-historia-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}@media(max-width:768px){.zdc-historia-inner{grid-template-columns:1fr;gap:40px}}.zdc-historia-label{font-family:'Bebas Neue',sans-serif;font-size:1rem;color:#E30517;letter-spacing:4px;margin:0 0 8px;text-transform:uppercase}.zdc-historia-line{width:60px;height:3px;background:#E30517;margin-bottom:30px}.zdc-historia-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.2rem,5vw,3.5rem);color:#fff;margin:0 0 25px;line-height:1.1}.zdc-historia-text{font-family:'Barlow Condensed',sans-serif;font-size:1.05rem;color:rgba(255,255,255,0.75);line-height:1.8;font-weight:300}.zdc-historia-text strong{color:#E30517;font-weight:600}.zdc-historia-img-wrap{position:relative;overflow:hidden;border-radius:4px}.zdc-historia-img-wrap img{width:100%;height:100%;object-fit:cover;display:block;clip-path:polygon(0 0,100% 0,100% 85%,0 100%);min-height:400px}.zdc-historia-img-wrap::after{content:'';position:absolute;bottom:0;left:0;right:0;height:40%;background:linear-gradient(transparent,rgba(7,14,35,0.6))}<\/style><div class=\"zdc-historia\"><div class=\"zdc-historia-inner\"><div class=\"zdc-r\"><span class=\"zdc-historia-label\">Nuestra Historia<\/span><div class=\"zdc-historia-line\"><\/div><h2 class=\"zdc-historia-title\">NACIMOS PARA FORMAR GUERREROS<\/h2><p class=\"zdc-historia-text\">En <strong>2021<\/strong>, en el corazón de Medellín, nació <strong>Zona de Combate<\/strong> con un sueño claro: crear el mejor gimnasio de artes marciales mixtas en Colombia.<br><br>Desde nuestros inicios en <strong>El Poblado<\/strong>, hemos crecido hasta convertirnos en una comunidad de más de <strong>100 alumnos activos<\/strong>, con los espacios más amplios y cómodos de la ciudad.<br><br>Nuestra historia no ha sido fácil. Después de una inundación que destruyó nuestras instalaciones, <strong>reconstruimos todo desde cero<\/strong>, más fuertes y con más determinación que nunca. Esa resiliencia es lo que nos define y lo que transmitimos a cada persona que entra por nuestras puertas.<br><br>Hoy, con <strong>instructores 100% formados<\/strong> que han competido profesionalmente, seguimos construyendo guerreros dentro y fuera del ring.<\/p><\/div><div class=\"zdc-historia-img-wrap zdc-r\"><img src=\"{{ 'zdc-dsc00385.jpg' | asset_url }}\" alt=\"Entrenador Zona de Combate\" loading=\"lazy\"><\/div><\/div><\/div>","color_scheme":"scheme-1","padding_top":0,"padding_bottom":0}},"valores":{"type":"custom-liquid","settings":{"custom_liquid":"<style>.zdc-valores{background:#0a1230;padding:100px 20px}.zdc-valores-header{text-align:center;max-width:700px;margin:0 auto 60px}.zdc-valores-header span{font-family:'Bebas Neue',sans-serif;font-size:1rem;color:#E30517;letter-spacing:4px}.zdc-valores-header h2{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.5rem,5vw,3.5rem);color:#fff;margin:15px 0 0}.zdc-valores-grid{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:30px}@media(max-width:768px){.zdc-valores-grid{grid-template-columns:1fr}}.zdc-valor-card{background:rgba(255,255,255,0.04);border-top:4px solid #E30517;padding:50px 35px;text-align:center;border-radius:4px;transition:transform 0.4s ease,background 0.4s ease}.zdc-valor-card:hover{transform:translateY(-8px);background:rgba(255,255,255,0.08)}.zdc-valor-num{font-family:'Bebas Neue',sans-serif;font-size:3.5rem;color:#E30517;line-height:1;margin-bottom:15px}.zdc-valor-card h3{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;color:#fff;letter-spacing:3px;margin:0 0 15px}.zdc-valor-card p{font-family:'Barlow Condensed',sans-serif;font-size:1rem;color:rgba(255,255,255,0.65);line-height:1.7;font-weight:300}<\/style><div class=\"zdc-valores\"><div class=\"zdc-valores-header zdc-r\"><span>LO QUE NOS DEFINE<\/span><h2>NUESTROS VALORES<\/h2><\/div><div class=\"zdc-valores-grid\"><div class=\"zdc-valor-card zdc-r\"><div class=\"zdc-valor-num\">01<\/div><h3>LEALTAD<\/h3><p>Somos fieles a nuestro equipo, a nuestro proceso y a cada persona que confía en nosotros. En Zona de Combate, la lealtad se demuestra cada día en el tatami.<\/p><\/div><div class=\"zdc-valor-card zdc-r\"><div class=\"zdc-valor-num\">02<\/div><h3>RESPETO<\/h3><p>Respetamos a nuestros compañeros, a nuestros rivales y a nosotros mismos. El respeto es la base de todo guerrero verdadero.<\/p><\/div><div class=\"zdc-valor-card zdc-r\"><div class=\"zdc-valor-num\">03<\/div><h3>HONESTIDAD<\/h3><p>Entrenamos con verdad, hablamos con verdad y competimos con verdad. No hay atajos en el camino del guerrero.<\/p><\/div><\/div><\/div>","color_scheme":"scheme-1","padding_top":0,"padding_bottom":0}},"disciplinas":{"type":"custom-liquid","settings":{"custom_liquid":"<style>.zdc-disc{background:#070E23;padding:100px 20px}.zdc-disc-header{text-align:center;max-width:700px;margin:0 auto 60px}.zdc-disc-header span{font-family:'Bebas Neue',sans-serif;font-size:1rem;color:#E30517;letter-spacing:4px}.zdc-disc-header h2{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.5rem,5vw,3.5rem);color:#fff;margin:15px 0 0}.zdc-disc-grid{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:20px}@media(max-width:900px){.zdc-disc-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:550px){.zdc-disc-grid{grid-template-columns:1fr}}.zdc-disc-card{position:relative;height:320px;border-radius:4px;overflow:hidden;cursor:pointer}.zdc-disc-card img{width:100%;height:100%;object-fit:cover;transition:transform 0.6s ease}.zdc-disc-card:hover img{transform:scale(1.08)}.zdc-disc-card-overlay{position:absolute;inset:0;background:linear-gradient(0deg,rgba(7,14,35,0.9) 0%,rgba(7,14,35,0.4) 50%,rgba(7,14,35,0.2) 100%);display:flex;flex-direction:column;justify-content:flex-end;padding:30px;transition:background 0.4s ease}.zdc-disc-card:hover .zdc-disc-card-overlay{background:linear-gradient(0deg,rgba(227,5,23,0.85) 0%,rgba(7,14,35,0.5) 60%,rgba(7,14,35,0.3) 100%)}.zdc-disc-card h3{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;color:#fff;letter-spacing:2px;margin:0 0 8px}.zdc-disc-card p{font-family:'Barlow Condensed',sans-serif;font-size:0.95rem;color:rgba(255,255,255,0.8);font-weight:300;line-height:1.5;margin:0}<\/style><div class=\"zdc-disc\"><div class=\"zdc-disc-header zdc-r\"><span>ENTRENA CON LOS MEJORES<\/span><h2>NUESTRAS DISCIPLINAS<\/h2><\/div><div class=\"zdc-disc-grid\"><div class=\"zdc-disc-card zdc-r\"><img src=\"{{ 'zdc-dsc00393.jpg' | asset_url }}\" alt=\"MMA\" loading=\"lazy\"><div class=\"zdc-disc-card-overlay\"><h3>MMA<\/h3><p>Artes Marciales Mixtas: la disciplina más completa. Combinamos striking y grappling para formar peleadores integrales.<\/p><\/div><\/div><div class=\"zdc-disc-card zdc-r\"><img src=\"{{ 'zdc-dsc00374.jpg' | asset_url }}\" alt=\"Boxeo\" loading=\"lazy\"><div class=\"zdc-disc-card-overlay\"><h3>BOXEO<\/h3><p>El arte del puño. Mejora tu velocidad, precisión y potencia con técnicas de boxeo profesional.<\/p><\/div><\/div><div class=\"zdc-disc-card zdc-r\"><img src=\"{{ 'zdc-dsc00384.jpg' | asset_url }}\" alt=\"BJJ\" loading=\"lazy\"><div class=\"zdc-disc-card-overlay\"><h3>BJJ<\/h3><p>Jiu-Jitsu Brasileño: el arte suave. Domina el combate en el suelo con técnicas de sumisión y control.<\/p><\/div><\/div><div class=\"zdc-disc-card zdc-r\"><img src=\"{{ 'zdc-dsc00380.jpg' | asset_url }}\" alt=\"Muay Thai\" loading=\"lazy\"><div class=\"zdc-disc-card-overlay\"><h3>MUAY THAI<\/h3><p>El arte de los ocho miembros. Golpes con puños, codos, rodillas y piernas al estilo tailandés.<\/p><\/div><\/div><div class=\"zdc-disc-card zdc-r\"><img src=\"{{ 'zdc-dsc00363.jpg' | asset_url }}\" alt=\"Lucha\" loading=\"lazy\"><div class=\"zdc-disc-card-overlay\"><h3>LUCHA \/ GRAPPLING<\/h3><p>Control y dominio corporal. Aprende derribos, proyecciones y técnicas de lucha olímpica.<\/p><\/div><\/div><div class=\"zdc-disc-card zdc-r\"><img src=\"{{ 'zdc-dsc00397.jpg' | asset_url }}\" alt=\"Acondicionamiento\" loading=\"lazy\"><div class=\"zdc-disc-card-overlay\"><h3>ACONDICIONAMIENTO FUNCIONAL<\/h3><p>Fuerza, resistencia y explosividad. Entrenamiento funcional diseñado para deportes de combate.<\/p><\/div><\/div><\/div><\/div>","color_scheme":"scheme-1","padding_top":0,"padding_bottom":0}},"equipo":{"type":"custom-liquid","disabled":true,"settings":{"custom_liquid":"<style>.zdc-equipo{background:#0a1230;padding:100px 20px}.zdc-equipo-header{text-align:center;max-width:800px;margin:0 auto 60px}.zdc-equipo-header span{font-family:'Bebas Neue',sans-serif;font-size:1rem;color:#E30517;letter-spacing:4px}.zdc-equipo-header h2{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.5rem,5vw,3.5rem);color:#fff;margin:15px 0 0}.zdc-equipo-header p{font-family:'Barlow Condensed',sans-serif;font-size:1.1rem;color:rgba(255,255,255,0.6);font-weight:300;margin-top:15px}.zdc-trainers{max-width:1100px;margin:0 auto 80px;display:grid;grid-template-columns:repeat(4,1fr);gap:25px}@media(max-width:900px){.zdc-trainers{grid-template-columns:repeat(2,1fr)}}@media(max-width:500px){.zdc-trainers{grid-template-columns:1fr;max-width:350px}}.zdc-trainer-card{background:rgba(255,255,255,0.04);border-radius:4px;overflow:hidden;transition:transform 0.4s ease}.zdc-trainer-card:hover{transform:translateY(-8px)}.zdc-trainer-img{position:relative;aspect-ratio:3\/4;overflow:hidden}.zdc-trainer-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.5s ease}.zdc-trainer-card:hover .zdc-trainer-img img{transform:scale(1.05)}.zdc-trainer-img::after{content:'';position:absolute;bottom:0;left:0;right:0;height:4px;background:#E30517;transform:scaleX(0);transition:transform 0.4s ease;transform-origin:left}.zdc-trainer-card:hover .zdc-trainer-img::after{transform:scaleX(1)}.zdc-trainer-info{padding:20px;text-align:center}.zdc-trainer-info h3{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#fff;letter-spacing:2px;margin:0 0 5px}.zdc-trainer-info span{font-family:'Barlow Condensed',sans-serif;font-size:0.9rem;color:#E30517;font-weight:500;letter-spacing:1px}.zdc-influencers{max-width:900px;margin:0 auto;text-align:center}.zdc-influencers h3{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;color:rgba(255,255,255,0.5);letter-spacing:3px;margin:0 0 25px}.zdc-influencer-tags{display:flex;flex-wrap:wrap;justify-content:center;gap:12px}.zdc-influencer-tag{font-family:'Barlow Condensed',sans-serif;font-size:0.9rem;color:rgba(255,255,255,0.7);background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);padding:8px 18px;border-radius:30px;transition:all 0.3s ease;text-decoration:none}.zdc-influencer-tag:hover{border-color:#E30517;color:#E30517;background:rgba(227,5,23,0.1)}<\/style><div class=\"zdc-equipo\"><div class=\"zdc-equipo-header zdc-r\"><span>NUESTRO EQUIPO<\/span><h2>CREAMOS GUERREROS<\/h2><p>Todos nuestros instructores han competido profesionalmente y están 100% formados para guiar tu proceso.<\/p><\/div><div class=\"zdc-trainers\"><div class=\"zdc-trainer-card zdc-r\"><div class=\"zdc-trainer-img\"><img src=\"{{ 'zdc-dsc00372.jpg' | asset_url }}\" alt=\"Jorge Loaiza\" loading=\"lazy\"><\/div><div class=\"zdc-trainer-info\"><h3>JORGE LOAIZA<\/h3><span>MMA<\/span><\/div><\/div><div class=\"zdc-trainer-card zdc-r\"><div class=\"zdc-trainer-img\"><img src=\"{{ 'zdc-dsc00374.jpg' | asset_url }}\" alt=\"Salomón Tabares\" loading=\"lazy\"><\/div><div class=\"zdc-trainer-info\"><h3>SALOMÓN TABARES<\/h3><span>BOXEO<\/span><\/div><\/div><div class=\"zdc-trainer-card zdc-r\"><div class=\"zdc-trainer-img\"><img src=\"{{ 'zdc-dsc00384.jpg' | asset_url }}\" alt=\"Iván Londoño\" loading=\"lazy\"><\/div><div class=\"zdc-trainer-info\"><h3>IVÁN LONDOÑO<\/h3><span>MUAY THAI<\/span><\/div><\/div><div class=\"zdc-trainer-card zdc-r\"><div class=\"zdc-trainer-img\"><img src=\"{{ 'zdc-dsc00354.jpg' | asset_url }}\" alt=\"Tomás Gutiérrez\" loading=\"lazy\"><\/div><div class=\"zdc-trainer-info\"><h3>TOMÁS GUTIÉRREZ<\/h3><span>BJJ<\/span><\/div><\/div><\/div><div class=\"zdc-influencers zdc-r\"><h3>INFLUENCERS QUE HAN ENTRENADO CON NOSOTROS<\/h3><div class=\"zdc-influencer-tags\"><a href=\"https:\/\/instagram.com\/westcol\" target=\"_blank\" class=\"zdc-influencer-tag\">@Westcol<\/a><a href=\"https:\/\/instagram.com\/oficial_mav\" target=\"_blank\" class=\"zdc-influencer-tag\">@Oficial_Mav<\/a><a href=\"https:\/\/instagram.com\/karinagarciaoficial\" target=\"_blank\" class=\"zdc-influencer-tag\">@KarinaGarciaOficial<\/a><a href=\"https:\/\/instagram.com\/pelicanger\" target=\"_blank\" class=\"zdc-influencer-tag\">@Pelicanger<\/a><a href=\"https:\/\/instagram.com\/elmune\" target=\"_blank\" class=\"zdc-influencer-tag\">@ElMune<\/a><a href=\"https:\/\/instagram.com\/manuelaqm\" target=\"_blank\" class=\"zdc-influencer-tag\">@ManuelAQM<\/a><a href=\"https:\/\/instagram.com\/milica_yb\" target=\"_blank\" class=\"zdc-influencer-tag\">@Milica_YB<\/a><\/div><\/div><\/div>","color_scheme":"scheme-1","padding_top":0,"padding_bottom":0}},"numeros":{"type":"custom-liquid","settings":{"custom_liquid":"<style>.zdc-numeros{background:#070E23;p