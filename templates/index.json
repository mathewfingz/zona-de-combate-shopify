oacute;n empieza aqu&iacute;.</p><div class=\"zdc-r\"><span class=\"zdc-presale-pill\">PREVENTA EXCLUSIVA</span></div><div class=\"zdc-r\"><a href=\"#zdc-pricing\" class=\"zdc-hero-cta\">QUIERO MI PLAN &mdash; $100.000 COP</a></div><div class=\"zdc-cd zdc-r\"><div class=\"zdc-cd-box\"><span class=\"zdc-cd-n\" id=\"zdc-d\">--</span><span class=\"zdc-cd-l\">D&iacute;as</span></div><div class=\"zdc-cd-box\"><span class=\"zdc-cd-n\" id=\"zdc-h\">--</span><span class=\"zdc-cd-l\">Horas</span></div><div class=\"zdc-cd-box\"><span class=\"zdc-cd-n\" id=\"zdc-m\">--</span><span class=\"zdc-cd-l\">Min</span></div><div class=\"zdc-cd-box\"><span class=\"zdc-cd-n\" id=\"zdc-s\">--</span><span class=\"zdc-cd-l\">Seg</span></div></div></div></div><script>(function(){var t=new Date('2026-04-15T23:59:59').getTime();function u(){var n=Date.now(),d=t-n;if(d<=0){document.getElementById('zdc-d').textContent='00';document.getElementById('zdc-h').textContent='00';document.getElementById('zdc-m').textContent='00';document.getElementById('zdc-s').textContent='00';return}var dd=Math.floor(d/864e5),hh=Math.floor((d%864e5)/36e5),mm=Math.floor((d%36e5)/6e4),ss=Math.floor((d%6e4)/1e3);document.getElementById('zdc-d').textContent=dd<10?'0'+dd:dd;document.getElementById('zdc-h').textContent=hh<10?'0'+hh:hh;document.getElementById('zdc-m').textContent=mm<10?'0'+mm:mm;document.getElementById('zdc-s').textContent=ss<10?'0'+ss:ss}u();setInterval(u,1000)})();document.addEventListener('DOMContentLoaded',function(){var els=document.querySelectorAll('.zdc-r');if('IntersectionObserver' in window){var idx=0;var ob=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting){var el=e.target;var delay=el.dataset.d||0;setTimeout(function(){el.classList.add('zdc-v')},delay);ob.unobserve(el)}})},{threshold:.12});els.forEach(function(el,i){el.dataset.d=i*80;ob.observe(el)})}else{els.forEach(function(el){el.classList.add('zdc-v')})}});</script>",
