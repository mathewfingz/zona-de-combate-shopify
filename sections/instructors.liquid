<style>
.instructors{background:#000000;padding:80px 0;overflow:hidden}
.instructors-inner{max-width:1200px;margin:0 auto;padding:0 20px}
.instructors-header{text-align:center;margin-bottom:56px}
.instructors-header h2{font-size:clamp(2.2rem,5vw,3.5rem);text-transform:uppercase;color:#fff;margin-bottom:8px;letter-spacing:2px}
.instructors-header p{font-size:1.1rem;color:#888;max-width:500px;margin:0 auto}
.instructors-header .accent-line{width:60px;height:3px;background:#E30517;margin:16px auto 0;border-radius:2px}
.instructors-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:20px}
.instructor-card{position:relative;border-radius:16px;overflow:hidden;background:#0a0a0a;transition:transform .4s cubic-bezier(.22,1,.36,1),box-shadow .4s}
.instructor-card:hover{transform:translateY(-8px);box-shadow:0 20px 50px rgba(227,5,23,.15)}
.instructor-img{width:100%;aspect-ratio:3/4;overflow:hidden;position:relative;background:#1a2332}
.instructor-img img{width:100%;height:100%;object-fit:cover;transition:transform .6s cubic-bezier(.22,1,.36,1);filter:grayscale(30%)}
.instructor-card:hover .instructor-img img{transform:scale(1.08);filter:grayscale(0)}
.instructor-img::after{content:'';position:absolute;bottom:0;left:0;width:100%;height:60%;background:linear-gradient(to top,#0a0a0a,transparent);pointer-events:none}
.instructor-img .placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#333;font-size:.8rem;text-transform:uppercase;letter-spacing:1px}
.instructor-info{padding:20px 16px 24px;position:relative;text-align:center}
.instructor-info h3{font-size:1.1rem;text-transform:uppercase;color:#fff;margin-bottom:4px;letter-spacing:1px}
.instructor-info .specialty{font-size:.75rem;text-transform:uppercase;letter-spacing:2px;color:#E30517;font-weight:700;margin-bottom:12px}
.instructor-info .bio{font-size:.82rem;color:#777;line-height:1.6;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;transition:all .3s}
.instructor-card:hover .bio{-webkit-line-clamp:unset}
.instructor-social{display:flex;justify-content:center;gap:8px;margin-top:12px;opacity:0;transform:translateY(8px);transition:all .3s}
.instructor-card:hover .instructor-social{opacity:1;transform:translateY(0)}
.instructor-social a{width:30px;height:30px;border-radius:50%;background:rgba(227,5,23,.15);display:flex;align-items:center;justify-content:center;transition:background .3s}
.instructor-social a:hover{background:#E30517}
.instructor-social a svg{width:14px;height:14px;fill:#fff}
@media(max-width:968px){.instructors-grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:600px){.instructors-grid{grid-template-columns:repeat(2,1fr);gap:12px}.instructor-info{padding:14px 10px 18px}.instructor-info h3{font-size:.95rem}.instructor-info .bio{font-size:.78rem;-webkit-line-clamp:2}}
</style>

<section class="instructors" id="instructors">
  <div class="instructors-inner">
    <div class="instructors-header">
      <h2>{{ section.settings.heading | default: 'TUS ENTRENADORES' }}</h2>
      <p>{{ section.settings.subheading | default: 'Peleadores profesionales que te guían paso a paso' }}</p>
      <div class="accent-line"></div>
    </div>
    <div class="instructors-grid">
      {% for block in section.blocks %}
        <div class="instructor-card" {{ block.shopify_attributes }}>
          <div class="instructor-img">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.name }}
            {% else %}
              <div class="placeholder">Subir foto</div>
            {% endif %}
          </div>
          <div class="instructor-info">
            <h3>{{ block.settings.name }}</h3>
            <div class="specialty">{{ block.settings.specialty }}</div>
            <p class="bio">{{ block.settings.bio }}</p>
            {% if block.settings.instagram != blank %}
            <div class="instructor-social">
              <a href="{{ block.settings.instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
                <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
            </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Instructores",
  "tag": "section",
  "class": "section-instructors",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "TUS ENTRENADORES"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Peleadores profesionales que te guían paso a paso"
    }
  ],
  "blocks": [
    {
      "type": "instructor",
      "name": "Instructor",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Foto del instructor"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre",
          "default": "Nombre del instructor"
        },
        {
          "type": "text",
          "id": "specialty",
          "label": "Especialidad",
          "default": "MMA / Boxeo"
        },
        {
          "type": "textarea",
          "id": "bio",
          "label": "Biografía"
        },
        {
          "type": "url",
          "id": "instagram",
          "label": "Instagram URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instructores",
      "blocks": [
        {
          "type": "instructor",
          "settings": {
            "name": "Jorge Loaiza",
            "specialty": "Boxeo · Muay Thai · MMA",
            "bio": "Peleador profesional en artes marciales mixtas y Muay Thai, reconocido por su disciplina, exigencia y alto nivel técnico."
          }
        }
      ]
    }
  ]
}
{% endschema %}
